{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.JoeCardoso13/greenhouse",
  "title": "Greenhouse",
  "description": "MCP server for the public Greenhouse Job Board API, focused on polling boards and normalizing job postings.",
  "version": "0.1.0",
  "websiteUrl": "https://github.com/JoeCardoso13",
  "repository": {
    "url": "https://github.com/JoeCardoso13/mcp-greenhouse",
    "source": "github"
  },
  "packages": [
    {
      "registryType": [
        "mcpb",
        "pypi"
      ],
      "registryBaseUrl": "https://pypi.org",
      "identifier": "mcp-greenhouse",
      "version": "0.1.0",
      "transport": {
        "type": "stdio"
      }
    }
  ],
  "_meta": {
    "io.modelcontextprotocol.registry/publisher-provided": {
      "tool": "mcpb",
      "version": "0.4"
    },
    "org.mpaktrust": {
      "mtf_version": "0.1",
      "permissions": {
        "network": [
          "boards-api.greenhouse.io"
        ],
        "filesystem": "none",
        "subprocess": "none"
      }
    }
  }
}
